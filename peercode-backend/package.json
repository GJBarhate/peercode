{
  "name": "peercode-backend",
  "version": "1.0.0",
  "description": "PeerCode backend API server",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "lint": "eslint src/ server.js --ext .js",
    "test": "jest --runInBand",
    "seed:problems": "node src/seeds/problemSeed.js",
    "seed:tracks": "node src/seeds/trackSeed.js"
  },
  "dependencies": {
    "@google/generative-ai": "^0.24.1",
    "@sendgrid/mail": "^8.1.6",
    "@socket.io/redis-adapter": "^8.3.0",
    "agenda": "5.0.0",
    "axios": "^1.17.0",
    "bcryptjs": "2.4.3",
    "compression": "1.7.4",
    "cookie-parser": "1.4.6",
    "cors": "2.8.5",
    "dotenv": "16.3.1",
    "express": "4.18.2",
    "express-async-errors": "3.1.1",
    "express-mongo-sanitize": "2.2.0",
    "express-rate-limit": "7.1.0",
    "google-auth-library": "^9.15.1",
    "helmet": "7.1.0",
    "ioredis": "^5.3.2",
    "joi": "^18.2.3",
    "jsonwebtoken": "9.0.0",
    "mongoose": "8.0.0",
    "morgan": "1.10.0",
    "nodemailer": "6.9.7",
    "rate-limit-redis": "^4.2.0",
    "razorpay": "^2.9.6",
    "socket.io": "4.7.2",
    "socket.io-client": "^4.8.3",
    "uuid": "9.0.0"
  },
  "devDependencies": {
    "jest": "29.0.0",
    "lint-staged": "^15.2.0",
    "nodemon": "3.0.0",
    "prettier": "^3.3.0",
    "supertest": "6.3.3"
  },
  "lint-staged": {
    "src/**/*.js": [
      "prettier --write"
    ],
    "*.js": [
      "prettier --write"
    ]
  },
  "jest": {
    "testEnvironment": "node",
    "testMatch": [
      "**/__tests__/**/*.js",
      "**/*.test.js"
    ]
  }
}
